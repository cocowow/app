// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Character {
  id        String   @id @default(uuid()) 
  name      String   @unique
  createdAt DateTime @default(now())
  wins      Int      @default(0)
  losses    Int      @default(0)
  ties      Int      @default(0)
  createdBy   User?   @relation("CharacterCreatedBy", fields: [createdById], references: [id])
  createdById String?
}

model User {
  id       String @id @default(uuid())
  username String @unique
  salt     String  
  hash     String  
  createdAt DateTime @default(now())
  sessionToken   String?   @unique
  tokenCreatedAt DateTime?
  lastActive     DateTime?
  
  characters   Character[]   @relation("CharacterCreatedBy")
}



